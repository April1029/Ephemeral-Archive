# Gemini (text + image generation)
GEMINI_API_KEY=

# Turso (database)
# Get these from turso.tech after creating a database
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# Cloudflare R2 (image storage)
# Get these from Cloudflare dashboard → R2 → your bucket → API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nowever-images
R2_PUBLIC_URL=https://pub-xxxx.r2.dev   # or your custom domain pointing to R2

# Local development only — override DB to a local file
# TURSO_DATABASE_URL=file:./data/nowever.sqlite
# (leave R2 vars unset to fall back to local public/generated-images/)
